{
  "name": "project-builder-v2",
  "version": "0.1.0",
  "description": "Layered flow orchestration engine — invoke agents programmatically via swappable backends",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "node --experimental-strip-types src/main.ts --model deepseek/deepseek-chat --runner pi-sdk",
    "ci": "node --experimental-strip-types src/main.ts --model deepseek/deepseek-chat --runner pi-sdk --gate auto-approve --yes",
    "interactive": "node --experimental-strip-types src/main.ts --runner pi-interactive",
    "resume": "node --experimental-strip-types src/main.ts --resume --model deepseek/deepseek-chat --runner pi-sdk --gate auto-approve --yes",
    "list": "node --experimental-strip-types src/main.ts --list-flows",
    "test": "node --experimental-strip-types --test test/engine/prompt-builder.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-agent-core": "*",
    "inquirer": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
